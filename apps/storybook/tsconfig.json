{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tinji/typescript-config/react-library.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["react", "react-dom", "node"]
  },
  "include": ["stories", ".storybook", "styles.css", "vite.config.ts"],
  "exclude": ["node_modules", "storybook-static"]
}
