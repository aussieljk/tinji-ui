{
  "name": "@tinji/cli",
  "version": "0.1.0",
  "description": "Branded CLI for the tinji ui component registry.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "bin": {
    "tinji": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "bun src/index.ts",
    "clean": "rm -rf dist node_modules",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@tinji/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
